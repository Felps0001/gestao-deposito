# Porta do servidor (no Render e injetada automaticamente)
PORT=4000

# Ambiente: "production" em producao (no Render). Em producao o JWT_SECRET e obrigatorio.
NODE_ENV=development

# Segredo para assinar os tokens JWT (use um valor forte em producao)
JWT_SECRET=troque-por-um-valor-bem-aleatorio

# Origens permitidas no CORS (URL do frontend). Varias separadas por virgula.
# Deixe vazio em desenvolvimento para liberar qualquer origem.
CORS_ORIGIN=https://gestao-deposito.pages.dev

# Credenciais do admin (usadas no seed para criar o usuario inicial)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=defina-uma-senha-forte

# MongoDB Atlas
MONGODB_URI=mongodb+srv://usuario:senha@cluster.mongodb.net/?appName=App
MONGODB_DB=gestao_deposito

# ---------- Cloudflare R2 (upload de imagens) ----------
# Deixe vazio em desenvolvimento para usar upload em disco (pasta uploads/).
R2_ENDPOINT=https://<account_id>.r2.cloudflarestorage.com
R2_BUCKET=gestao-deposito
R2_PREFIX=gestao_deposito_images
R2_PUBLIC_URL=https://pub-xxxxxxxx.r2.dev
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
